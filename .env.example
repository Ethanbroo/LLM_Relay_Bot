# LLM Relay Bot — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Core Bot ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
BOT_MODE=polling                   # "polling" for dev, "webhook" for production
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_OWNER_ID=123456789
TELEGRAM_ALLOWED_USERS=123456789
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=sk-...
WORKSPACE_PATH=/app/workspace

# ── Webhook (production only) ────────────────────────────────
BOT_DOMAIN=yourdomain.com
WEBHOOK_SECRET_TOKEN=a_random_secret_string
WEBHOOK_URL=https://yourdomain.com

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=a_strong_random_password_here
# REDIS_URL is set automatically in compose.yaml: redis://:${REDIS_PASSWORD}@redis:6379/0
# For local dev without Docker, set manually:
# REDIS_URL=redis://localhost:6379/0

# ── VPS Mode (Section 2) ─────────────────────────────────────
# Set CLAUDE_MAX_SESSION_TOKEN to enable VPS mode (Claude Code CLI).
# Leave unset for local dev (uses direct Anthropic API).
CLAUDE_MAX_SESSION_TOKEN=your_max_subscription_token
CODE_SERVER_PASSWORD=another_strong_password_here
GITHUB_PAT=ghp_...
PREVIEW_TIMEOUT_SECONDS=7200
TOKEN_BUDGET_DEFAULT=10.00
