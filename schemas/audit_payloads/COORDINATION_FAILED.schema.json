{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "COORDINATION_FAILED payload",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "coordination_id": {
      "type": "string",
      "description": "Coordination UUID"
    },
    "task_id": {
      "type": "string",
      "description": "Task identifier"
    },
    "action": {
      "type": "string",
      "description": "Action identifier"
    },
    "stage": {
      "type": "string",
      "enum": ["approval_check", "lock_acquisition", "deadlock_victim"],
      "description": "Stage where coordination failed"
    },
    "error_code": {
      "type": "string",
      "description": "Error code"
    },
    "error_message": {
      "type": "string",
      "description": "Error message"
    }
  },
  "required": ["coordination_id", "task_id", "action", "stage", "error_code", "error_message"]
}
