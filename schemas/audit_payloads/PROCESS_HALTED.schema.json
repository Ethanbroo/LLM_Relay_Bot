{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "title": "PROCESS_HALTED Payload",
  "description": "Emitted when a process component halts",
  "type": "object",
  "required": ["process_name", "pid", "reason"],
  "additionalProperties": false,
  "properties": {
    "process_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "reason": {
      "type": "string",
      "maxLength": 256
    },
    "exit_code": {
      "type": "integer"
    }
  }
}
