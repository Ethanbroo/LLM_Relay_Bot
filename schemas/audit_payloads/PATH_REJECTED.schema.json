{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "title": "PATH_REJECTED Payload",
  "description": "Emitted when path sanitization rejects unsafe path",
  "type": "object",
  "required": ["path", "reason"],
  "additionalProperties": false,
  "properties": {
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "reason": {
      "type": "string",
      "maxLength": 256
    }
  }
}
