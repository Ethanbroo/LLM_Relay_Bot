{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "title": "SANDBOX_DESTROYED Payload",
  "description": "Emitted when sandbox environment destroyed",
  "type": "object",
  "required": ["sandbox_id", "task_id"],
  "additionalProperties": false,
  "properties": {
    "sandbox_id": {
      "type": "string",
      "pattern": "^sandbox_[a-f0-9]{64}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
