{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "title": "ENGINE_HALTED Payload",
  "description": "Emitted when execution engine halts",
  "type": "object",
  "required": ["reason"],
  "additionalProperties": false,
  "properties": {
    "reason": {
      "type": "string",
      "maxLength": 512
    },
    "task_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
