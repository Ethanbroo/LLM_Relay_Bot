{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "title": "SECRET_REDACTED Payload",
  "description": "Emitted when secret detected and redacted from event payload",
  "type": "object",
  "required": ["event_type", "redacted_paths"],
  "additionalProperties": false,
  "properties": {
    "event_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "redacted_paths": {
      "type": "array",
      "description": "JSON pointer paths that were redacted",
      "items": {
        "type": "string",
        "pattern": "^/.*"
      }
    }
  }
}
