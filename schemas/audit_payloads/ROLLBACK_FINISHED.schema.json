{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "title": "ROLLBACK_FINISHED Payload",
  "description": "Emitted when rollback operation completes",
  "type": "object",
  "required": ["task_id", "snapshot_id", "success"],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "snapshot_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "success": {
      "type": "boolean"
    },
    "error_code": {
      "type": "string",
      "maxLength": 64
    }
  }
}
