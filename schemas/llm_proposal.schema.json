{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://llm-relay.local/schemas/llm_proposal.schema.json",
  "title": "LLMProposal",
  "description": "Phase 6: Parsed LLM proposal",
  "type": "object",
  "required": [
    "model",
    "proposal_text",
    "rationale_text",
    "confidence",
    "proposal_hash"
  ],
  "properties": {
    "model": {
      "type": "string",
      "enum": ["chatgpt", "claude", "gemini", "deepseek"]
    },
    "proposal_text": {
      "type": "string",
      "maxLength": 1000
    },
    "rationale_text": {
      "type": "string",
      "maxLength": 2000
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "proposal_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false
}
