{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://llm-relay.local/schemas/llm_request.schema.json",
  "title": "LLMRequest",
  "description": "Phase 6: LLM request envelope",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "run_id",
    "model",
    "prompt_hash",
    "task_hash",
    "constraints_hash"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "relay.llm_request"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "description": "UUID v7"
    },
    "model": {
      "type": "string",
      "enum": ["chatgpt", "claude", "gemini", "deepseek"]
    },
    "prompt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "task_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "constraints_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false
}
