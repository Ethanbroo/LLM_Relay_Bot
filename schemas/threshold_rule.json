{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://relay.schema/threshold_rule.json",
  "title": "ThresholdRule",
  "description": "Phase 7 threshold rule schema for monitoring",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "rule_id",
    "enabled",
    "metric_id",
    "operator",
    "threshold",
    "window",
    "severity",
    "action",
    "cooldown_ms",
    "hysteresis",
    "emit_incident"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "relay.threshold_rule"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "rule_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Deterministic rule identifier"
    },
    "enabled": {
      "type": "boolean"
    },
    "metric_id": {
      "type": "string",
      "enum": [
        "proc.rss_bytes",
        "proc.cpu_percent",
        "proc.open_fds",
        "proc.uptime_ms",
        "loop.tick_lag_ms",
        "queue.depth",
        "queue.oldest_age_ms",
        "exec.attempts_inflight",
        "exec.failures_per_min",
        "exec.rollback_failures_per_min",
        "log.backpressure_active",
        "log.ingest_buffer_depth",
        "log.last_event_seq",
        "log.verify_failures_per_min",
        "locks.held_count",
        "locks.waiting_count",
        "deadlock.detected_per_min",
        "approval.pending_count",
        "conn.calls_per_min",
        "conn.failures_per_min",
        "conn.idempotency_hits_per_min",
        "conn.oversize_rejections_per_min",
        "llm.parse_failures_per_min",
        "llm.consensus_fallbacks_per_min",
        "llm.latency_p95_ms"
      ]
    },
    "operator": {
      "type": "string",
      "enum": ["GT", "GTE", "LT", "LTE", "EQ", "NEQ"]
    },
    "threshold": {
      "description": "Number or bool depending on metric type"
    },
    "window": {
      "type": "object",
      "required": ["mode", "n"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "const": "consecutive",
          "description": "Only consecutive mode allowed in Phase 7"
        },
        "n": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of consecutive breaches required"
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": ["INFO", "WARN", "CRITICAL", "FATAL"]
    },
    "action": {
      "type": "string",
      "enum": [
        "NOOP",
        "THROTTLE_INGRESS",
        "PAUSE_NEW_TASKS",
        "REQUEST_APPROVAL",
        "RESTART_SUBSYSTEM",
        "HALT_SYSTEM"
      ]
    },
    "cooldown_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Minimum time between triggers"
    },
    "hysteresis": {
      "type": "object",
      "required": ["clear_after_n"],
      "additionalProperties": false,
      "properties": {
        "clear_after_n": {
          "type": "integer",
          "minimum": 1,
          "description": "Consecutive good samples to clear"
        }
      }
    },
    "emit_incident": {
      "type": "boolean"
    },
    "restart_target": {
      "type": "string",
      "enum": ["monitor_daemon", "log_daemon"],
      "description": "Required when action=RESTART_SUBSYSTEM"
    }
  }
}
