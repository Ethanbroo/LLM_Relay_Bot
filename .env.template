# ============================================================================
# SECTION 1: TELEGRAM BOT + VPS INFRASTRUCTURE
# ============================================================================

# === Telegram Bot Configuration ===
TELEGRAM_BOT_TOKEN=              # From BotFather (e.g., 123456:ABC-DEF1234...)
TELEGRAM_BOT_OWNER_ID=           # Your Telegram user ID (integer). Get from @userinfobot.
TELEGRAM_ALLOWED_USERS=          # Comma-separated user IDs (e.g., 123456,789012)
BOT_MODE=polling                 # "polling" for dev, "webhook" for production

# === Webhook (production only) ===
BOT_DOMAIN=                      # e.g., yourdomain.com
WEBHOOK_SECRET_TOKEN=            # Generate with: python -c "import secrets; print(secrets.token_urlsafe(192))"
WEBHOOK_URL=                     # e.g., https://yourdomain.com (full URL for Telegram API)

# === Classifier ===
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# === Voice Transcription ===
# OPENAI_API_KEY is defined above in Phase 6 section. Leave empty to disable voice support.

# === Redis (Docker production) ===
REDIS_PASSWORD=                  # Strong password for Redis auth. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# REDIS_URL is set automatically in compose.yaml: redis://:${REDIS_PASSWORD}@redis:6379/0

# === Code Server ===
CODE_SERVER_PASSWORD=            # Password for browser-based VS Code

# === Claude Code / VPS Mode (Section 2) ===
# Set CLAUDE_MAX_SESSION_TOKEN to enable VPS mode (Claude Code CLI).
# Leave commented/unset for local dev (uses direct Anthropic API).
# CLAUDE_MAX_SESSION_TOKEN=      # Max subscription session token
# GITHUB_PAT=                    # GitHub personal access token

# === Workspace ===
WORKSPACE_PATH=/app/workspace    # Where projects are built (mapped Docker volume)

# === Budget / Preview ===
# PREVIEW_TIMEOUT_SECONDS=7200   # How long preview servers stay alive
# TOKEN_BUDGET_DEFAULT=10.00     # Default token budget per session

# ============================================================================
# NOTES
# ============================================================================
#
# - The LLM_RELAY_SECRET_ prefix is REQUIRED for connector secrets
# - Phase 5 connectors use SecretsProvider to access these values
# - Secrets are automatically redacted from Phase 3 audit logs
# - Never hardcode credentials in code or config files
# - Use different API keys for development, staging, and production
#
